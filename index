  <div class="sl">Próximos 3 dias</div><div id="hup"></div>
</div>

<!-- TRABALHO -->
<div id="s-work" class="screen">
  <div class="sh" style="background:var(--surface)">
    <span style="font-size:20px">🎠</span>
