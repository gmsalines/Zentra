async function sbA(table, method, body, filter){
  let url = SBU2 + '/rest/v1/' + table + (filter ? '?' + filter : '');
  const h = {apikey: SBK2, Authorization: H['Authorization'], 'Content-Type': 'application/json', Prefer: 'return=representation'};
