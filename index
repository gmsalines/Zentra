  if(pass.length<6){err.textContent='A senha precisa de 6+ caracteres.';return;}
  err.textContent='Criando conta...';
  try{
    const r=await fetch(SUPA_URL+'/auth/v1/signup',{method:'POST',headers:{'apikey':SUPA_KEY,'Content-Type':'application/json'},body:JSON.stringify({email,password:pass})});
    const d=await r.json();
    if(d.access_token){
      H['Authorization']='Bearer '+d.access_token;
      if(d.refresh_token) localStorage.setItem('z-refresh',d.refresh_token);
      try{localStorage.setItem('z-name',email.split('@')[0]);var _hg=document.getElementById('hgreet');if(_hg)_hg.textContent=email.split('@')[0];}catch(e){}
      document.getElementById('z-login').style.display='none';
      err.textContent=''; renderHome();
