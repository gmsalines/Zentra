    } else if(parsed?.action === 'add_compras'){
      await Promise.all(parsed.items.map(n=>sbA('compras','POST',{nome:n,qtd:1,done:false},null)));
      addMsg('bot', '✅ Adicionado à lista: ' + parsed.items.join(', ') + ' — indo para Compras...');
      setTimeout(()=>navTo('fin','comp'),600);
    } else if(parsed?.action === 'add_gasto'){
      await sbA('gastos','POST',{descricao:parsed.descricao,val:parsed.val,cur:parsed.cur||'BRL',cat:parsed.cat||'Outro',banco:parsed.banco||null,data:todayStr},null);
      addMsg('bot', '✅ Gasto registrado: ' + parsed.descricao + ' ' + parsed.val + ' ' + (parsed.cur||'BRL') + ' — indo para Gastos...');
      setTimeout(()=>navTo('fin','gastos'),600);
    } else if(parsed?.action === 'add_treino'){
      await sbA('registros','POST',{tipo:'academia',valor:parsed.tipo||'musculacao',notas:(parsed.min?parsed.min+'min':''),data:todayStr},null);
      const acum=ls('zentra-acum',0);lss('zentra-acum',acum+1);
      addMsg('bot', '✅ Treino registrado!' + (parsed.min?' '+parsed.min+'min':'') + ' — indo para Saúde...');
      setTimeout(()=>navTo('saude'),600);
    } else if(parsed?.action === 'add_peso'){
      await sbA('registros','POST',{tipo:'peso',valor:parsed.valor,data:todayStr},null);
      addMsg('bot', '✅ Peso: ' + parsed.valor + ' kg — indo para Saúde...');
      setTimeout(()=>navTo('saude'),600);
    } else {
      addMsg('bot', reply);
    }
  } catch(e) {
    document.getElementById('typing-indicator')?.remove();
    addMsg('bot', '⚠️ Erro ao conectar. Tenta de novo!');
    console.error(e);
  }
}
// ===== FIM CHAT =====

</script>
