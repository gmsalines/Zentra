// API
async function api(table,method,body,filter){
  try{
    let url=SUPA_URL+'/rest/v1/'+table;
    if(filter)url+='?'+filter;
    const o={method,headers:{...H}};
    if(body)o.body=JSON.stringify(body);
    if(method==='POST')o.headers['Prefer']='return=representation';
    const r=await fetch(url,o);
    if(r.status===204)return true;
    const t=await r.text();
    if(!r.ok){console.error('API',method,table,r.status,t);return null;}
    try{return JSON.parse(t);}catch{return t||null;}
  }catch(e){
    console.error('API error:',table,method,e);
    return [];
  }
}

