<!-- PESSOAL -->
<div id="s-pessoal" class="screen">
  <div class="sh" style="background:var(--surface)">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.3" stroke-linecap="round"><path d="M3,18 Q8,21 14,20 Q20,19 21,15 Q19,12 14,12 Q9,12 8,15 Q5,18 3,18Z"/><path d="M14,12 Q16,6 13,4 Q10,2 8,6 Q7,9 8,15"/></svg>
    <span style="font-family:Georgia,serif;font-size:17px;font-weight:700;color:var(--gold)">Pessoal</span>
  </div>
  <div id="ps-main" class="ss active">
    <div class="fr">
      <button class="fb on" onclick="fPes(this,'all')">Todas</button>
