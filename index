async function impHandle(file){
  if(!file)return;
  impFileName=file.name||'';
  document.getElementById('imp-modal').style.display='flex';
  var body=document.getElementById('impbody');body.innerHTML='<div class="dt">Lendo arquivo...</div>';
  document.getElementById('impbtn').disabled=true;
  var texto='';
  try{
    var name=(file.name||'').toLowerCase();
    if(name.endsWith('.pdf')){
      pdfjsLib.GlobalWorkerOptions.workerSrc='https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
      var buf=await file.arrayBuffer();
      var pdf=await pdfjsLib.getDocument({data:buf}).promise;
      for(var i=1;i<=pdf.numPages;i++){var pg=await pdf.getPage(i);var tc=await pg.getTextContent();texto+=tc.items.map(function(it){return it.str;}).join(' ')+'\n';}
    } else {
      var ab=await file.arrayBuffer();
      var wb=XLSX.read(ab,{type:'array'});
      texto=XLSX.utils.sheet_to_csv(wb.Sheets[wb.SheetNames[0]]);
    }
  }catch(e){body.innerHTML='<div class="empty">Nao consegui ler o arquivo: '+String(e).slice(0,80)+'</div>';return;}
  if(!texto.trim()){body.innerHTML='<div class="empty">Arquivo vazio ou ilegivel.</div>';return;}
  body.innerHTML='<div class="dt">Analisando lancamentos com IA...</div>';
  texto=texto.slice(0,12000);
  var prompt='Extraia os GASTOS/DESPESAS deste extrato bancario. Responda APENAS um array JSON, sem texto extra: [{"data":"YYYY-MM-DD","descricao":"texto curto","val":12.34,"cur":"BRL","cat":"Alimentacao|Transporte|Academia|Saude|Lazer|Estudo|Casa|Outro"}]. Regras: so SAIDAS/debitos/despesas (ignore entradas, creditos, saldos, transferencias recebidas, pagamentos recebidos). val sempre positivo. Se a moeda nao estiver clara use BRL. Escolha a categoria mais provavel pela descricao. Extrato:\n'+texto;
  try{
    var res=await fetch('/api/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({prompt:prompt,max_tokens:6000})});
    var data=await res.json();
    var c=((data&&data.choices&&data.choices[0]&&data.choices[0].message&&data.choices[0].message.content)||'').trim().replace(/```json|```/g,'').trim();
    var mm=c.match(/\[[\s\S]*\]/);if(mm)c=mm[0];
    var rows=JSON.parse(c);
    impRows=Array.isArray(rows)?rows:[];
  }catch(e){body.innerHTML='<div class="empty">A IA nao conseguiu extrair os lancamentos. Tenta um CSV mais simples (colunas data, descricao, valor).</div>';return;}
  impPreview();
}
function impPreview(){
  var body=document.getElementById('impbody');
  if(!impRows.length){body.innerHTML='<div class="empty">Nenhum gasto encontrado no arquivo.</div>';return;}
  var cats=['Alimentacao','Transporte','Academia','Saude','Lazer','Estudo','Casa','Outro'];
  var h='<div class="dt" style="margin-bottom:6px">'+impRows.length+' gastos encontrados. Desmarque os que nao quer e ajuste a categoria:</div>';
  h+=impRows.map(function(r,i){return '<div class="tr" style="flex-wrap:wrap;gap:4px;align-items:center"><input type="checkbox" checked onchange="impRows['+i+']._skip=!this.checked" style="width:18px;height:18px;flex-shrink:0"><input value="'+String(r.descricao||'').replace(/"/g,'&quot;')+'" onchange="impRows['+i+'].descricao=this.value" style="flex:1;min-width:110px;padding:4px;border:1px solid var(--border2);border-radius:6px;background:var(--surface2);color:var(--cream);font-size:12px"><input type="number" value="'+Number(r.val||0)+'" onchange="impRows['+i+'].val=parseFloat(this.value)" style="width:64px;padding:4px;border:1px solid var(--border2);border-radius:6px;background:var(--surface2);color:var(--cream);font-size:12px"><select onchange="impRows['+i+'].cur=this.value" style="padding:4px;border:1px solid var(--border2);border-radius:6px;background:var(--surface2);color:var(--cream);font-size:11px">'+['BRL','UYU','USD'].map(function(c){return '<option'+((r.cur===c)?' selected':'')+'>'+c+'</option>';}).join('')+'</select><input type="date" value="'+(r.data||'')+'" onchange="impRows['+i+'].data=this.value" style="padding:4px;border:1px solid var(--border2);border-radius:6px;background:var(--surface2);color:var(--cream);font-size:11px"><select onchange="impRows['+i+'].cat=this.value" style="font-size:11px;padding:4px;border:1px solid var(--border2);border-radius:6px;background:var(--surface2);color:var(--cream)">'+cats.map(function(c){return '<option'+((r.cat===c)?' selected':'')+'>'+c+'</option>';}).join('')+'</select></div>';}).join('');
  body.innerHTML=h;
  document.getElementById('impbtn').disabled=false;
}
async function impSave(){
  var sel=impRows.filter(function(r){return !r._skip;});
  if(!sel.length){closeImp();return;}
  var b=document.getElementById('impbtn');b.disabled=true;b.textContent='Importando...';
  var payload=sel.map(function(r){return {descricao:String(r.descricao||'gasto').slice(0,120),val:Number(r.val||0),cur:r.cur||'BRL',cat:r.cat||'Outro',banco:null,data:(r.data&&/^\d{4}-\d{2}-\d{2}$/.test(r.data))?r.data:td()};});
