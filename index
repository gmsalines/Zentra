let chartCat=null,chartMensal=null;
async function renderGraf(){
  const d=await api('gastos','GET',null,'select=val,cur,cat,data&order=data.desc');
  const gastos=Array.isArray(d)?d:[];
  const t=ls('zentra-taxas',{usd:5.70,uyu:0.14});
  const mes=tm();

  // Por categoria — mês atual
  const catMap={};
  gastos.filter(g=>g.data&&g.data.startsWith(mes)).forEach(g=>{
    const brl=g.cur==='BRL'?Number(g.val):g.cur==='USD'?Number(g.val)*t.usd:Number(g.val)*t.uyu;
    catMap[g.cat]=(catMap[g.cat]||0)+brl;
  });
  const catsK=Object.keys(catMap).sort((a,b)=>catMap[b]-catMap[a]);
  const cores=['#6A8FD4','#E87AB8','#7AB8E8','#A8C4F0','#E8C87A','#7AE8B8','#E87A7A','#B87AE8'];

  const ctxCat=document.getElementById('chart-cat');
  if(chartCat){chartCat.destroy();chartCat=null;}
  if(catsK.length){
    chartCat=new Chart(ctxCat,{type:'doughnut',data:{labels:catsK,datasets:[{data:catsK.map(c=>catMap[c].toFixed(2)),backgroundColor:cores,borderWidth:0}]},options:{plugins:{legend:{labels:{color:'#A0B4D8',font:{size:12}}}},cutout:'65%'}});
  } else {
    ctxCat.parentElement.innerHTML='<div class="empty">Sem gastos este mês</div>';
  }

  // Evolução mensal — últimos 6 meses
  const meses=[];
  for(let i=5;i>=0;i--){const d=new Date();d.setMonth(d.getMonth()-i);meses.push(d.toISOString().slice(0,7));}
  const totMes=meses.map(m=>gastos.filter(g=>g.data&&g.data.startsWith(m)&&g.cur==='BRL').reduce((s,g)=>s+Number(g.val),0));
  const labMes=meses.map(m=>{const[y,mo]=m.split('-');return['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'][parseInt(mo)-1];});

