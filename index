function du(d){if(!d)return null;const a=new Date(d+'T00:00:00'),b=new Date();b.setHours(0,0,0,0);return Math.ceil((a-b)/864e5);}
function uc(d){const n=du(d);if(n===null)return'';if(n<=0)return'urgent';if(n<=3)return'warn';return'';}
function ul(d){const n=du(d);if(n===null)return'';if(n<0)return'<span class="utag ured">'+Math.abs(n)+'d atraso</span>';if(n===0)return'<span class="utag ured">Hoje</span>';if(n<=3)return'<span class="utag uamb">'+n+'d</span>';return'';}
function fd(s){if(!s)return'';const p=s.slice(0,10).split('-');return p[2]+'/'+p[1];}
