    </div>
  </div>
  <div id="hbanner" style="display:none" class="banner"><span style="font-size:18px">⚠️</span><span style="font-size:13px;color:#F0A090;flex:1" id="hbannertext"></span></div>
  <div class="sg">
    <div class="stat"><div class="sn" id="su" style="color:var(--red)">–</div><div class="sl-label">Urgentes</div></div>
    <div class="stat"><div class="sn" id="sp">–</div><div class="sl-label">Pendentes</div></div>
    <div class="stat"><div class="sn" id="sb2" style="color:var(--gold)">–</div><div class="sl-label">Contas vencer</div></div>
    <div class="stat"><div class="sn" id="sm" style="color:var(--moss)">–</div><div class="sl-label">Gastos BRL</div></div>
