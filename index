<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black">
<meta name="apple-mobile-web-app-title" content="Zentra">
<meta name="theme-color" content="#0A0E1A">
<title>Zentra — Your missing wand.</title>
<link rel="manifest" href="/manifest.json">
<link rel="apple-touch-icon" href="/icon-180.png">
<link rel="icon" type="image/png" href="/icon-192.png">
<style>
:root{--bg:#0A0E1A;--surface:#060A12;--surface2:#04080F;--gold:#6A8FD4;--gold2:#A8C4F0;--cream:#E8EEF8;--cream2:#A0B4D8;--moss:#7AB8E8;--terra:#E87AB8;--red:#E87070;--border:#141C2E;--border2:#1E2A40;--text:#E8EEF8;--text2:#7A9CC8;--text3:#3A5A8A;--r:14px;--rs:8px;}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
body{font-family:-apple-system,BlinkMacSystemFont,sans-serif;background:var(--bg);color:var(--text);font-size:15px;min-height:100vh;}
#app{max-width:480px;margin:0 auto;min-height:100vh;position:relative;}
.screen{display:none;padding:1rem 1rem 5.5rem;min-height:100vh;}.screen.active{display:block;}
.bnav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:var(--surface2);border-top:1px solid var(--border);display:flex;z-index:100;padding-bottom:env(safe-area-inset-bottom);}
.nb{flex:1;padding:10px 2px 8px;background:transparent;border:none;cursor:pointer;font-size:9px;color:var(--text3);display:flex;flex-direction:column;align-items:center;gap:4px;font-family:inherit;letter-spacing:.02em;transition:color .15s;}

.nb.on{color:var(--gold);}
.topbar{padding:.75rem 0 1.25rem;}
.tdate{font-size:12px;color:var(--text2);margin-bottom:2px;}
.ttitle{font-family:Georgia,serif;font-size:22px;font-weight:700;color:var(--cream);}
.trow{display:flex;justify-content:space-between;align-items:flex-end;}
.avatar{display:flex;align-items:center;flex-shrink:0;}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:12px 14px;margin-bottom:8px;}
.card.urgent{border-left:3px solid var(--red);}.card.warn{border-left:3px solid var(--gold);}
.sg{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:1.25rem;}
.stat{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:.85rem 1rem;}
.sn{font-size:26px;font-weight:600;line-height:1;font-family:Georgia,serif;}
.sl-label{font-size:11px;color:var(--text2);margin-top:4px;}
.sl{font-size:11px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.06em;margin:1.25rem 0 .6rem;}
.sl:first-child{margin-top:0;}
.tr{display:flex;align-items:flex-start;gap:10px;padding:12px 14px;background:var(--surface);border:1px solid var(--border);border-radius:var(--r);margin-bottom:8px;}
.tr.done{opacity:.4;}.tr.done .tx{text-decoration:line-through;}
.tr.urgent{border-left:3px solid var(--red);}.tr.warn{border-left:3px solid var(--gold);}
.cb{width:22px;height:22px;border-radius:50%;border:2px solid var(--border2);background:transparent;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;margin-top:1px;transition:all .15s;}
.cb.on{background:var(--moss);border-color:var(--moss);}
.tx{flex:1;font-size:14px;line-height:1.4;color:var(--cream);}
.txm{display:flex;gap:5px;flex-wrap:wrap;margin-top:4px;align-items:center;}
.xb{background:transparent;border:none;cursor:pointer;color:var(--text3);font-size:20px;line-height:1;padding:0;flex-shrink:0;}
.badge{font-size:11px;padding:2px 8px;border-radius:20px;font-weight:500;}
.b0{background:#080E1A;color:var(--gold);border:.5px solid #4A3A20;}
.b1{background:#1A2228;color:#7AB8D4;border:.5px solid #2A4A5A;}
.b2{background:#1E2A1A;color:var(--moss);border:.5px solid #3A4A28;}
.b3{background:#2A1A18;color:var(--terra);border:.5px solid #4A2A20;}
.utag{font-size:11px;font-weight:600;}
.ured{color:var(--red);}.uamb{color:var(--gold);}
.fr{display:flex;gap:6px;margin-bottom:1rem;overflow-x:auto;padding-bottom:2px;scrollbar-width:none;}
.fr::-webkit-scrollbar{display:none;}
.fb{padding:5px 12px;border:1px solid var(--border2);border-radius:20px;background:transparent;cursor:pointer;font-size:13px;color:var(--text2);white-space:nowrap;font-family:inherit;transition:all .15s;}
.fb.on{background:var(--gold);color:var(--surface2);border-color:var(--gold);font-weight:500;}
.ab{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:14px;margin-top:1rem;}
.ab input,.ab select,.ab textarea{width:100%;padding:9px 11px;font-size:14px;border:1px solid var(--border2);border-radius:var(--rs);background:var(--surface2);color:var(--cream);margin-bottom:8px;font-family:inherit;outline:none;}
.ab input:focus,.ab select:focus{border-color:var(--gold);}
.ab input::placeholder{color:var(--text3);}
.ab .rr{display:flex;gap:8px;margin-bottom:8px;}
.ab .rr input,.ab .rr select{margin:0;}
.ab select option{background:var(--surface2);}
.btn{width:100%;padding:10px;font-size:14px;border:1.5px solid var(--gold);border-radius:var(--rs);background:transparent;cursor:pointer;color:var(--gold);font-weight:600;font-family:inherit;margin-top:4px;transition:background .15s;}
.btn:hover{background:#3A2A10;}
.btn.pri{background:var(--gold);color:var(--surface2);}.btn.pri:hover{background:var(--gold2);}
.btn.dan{border-color:var(--red);color:var(--red);}
.t2{padding:5px 14px;border:1px solid var(--border2);border-radius:20px;background:transparent;cursor:pointer;font-size:13px;color:var(--text2);font-family:inherit;transition:all .15s;}
.t2.on{background:var(--cream);color:var(--surface2);border-color:var(--cream);font-weight:500;}
.sh{display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:var(--r);margin-bottom:1rem;}
.empty{text-align:center;padding:2.5rem 1rem;color:var(--text3);font-size:14px;}
.ss{display:none;}.ss.active{display:block;}
.back{display:flex;align-items:center;gap:6px;background:transparent;border:none;cursor:pointer;color:var(--text2);font-size:13px;font-family:inherit;padding:0;margin-bottom:1rem;}
.pbar{background:var(--border2);border-radius:4px;height:6px;overflow:hidden;margin-top:4px;}
.pfill{height:100%;border-radius:4px;transition:width .3s;}
.hgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:1rem;}
.hcard{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:16px 12px;cursor:pointer;text-align:center;transition:border-color .15s;}
.hcard:hover{border-color:var(--gold);}
.hci{font-size:28px;display:block;margin-bottom:6px;}
.hcn{font-size:13px;font-weight:500;color:var(--cream);}
.hcv{font-size:12px;color:var(--text2);margin-top:3px;}
.mo{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:200;align-items:flex-end;justify-content:center;}
.mo.active{display:flex;}
.moc{background:var(--surface);border-radius:var(--r) var(--r) 0 0;padding:1.25rem 1rem 2rem;width:100%;max-width:480px;}
.banner{background:#3A1A18;border:1px solid var(--red);border-radius:var(--r);padding:10px 14px;margin-bottom:1rem;display:flex;align-items:center;gap:10px;}
.hr-row{display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--surface);border:1px solid var(--border);border-radius:var(--rs);margin-bottom:6px;}
.hr-cb{width:22px;height:22px;border-radius:6px;border:2px solid var(--border2);background:transparent;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .15s;}
.hr-cb.on{background:var(--moss);border-color:var(--moss);color:white;font-size:12px;}
.amt{font-size:15px;font-weight:600;color:var(--gold);}
.amtc{font-size:11px;color:var(--text3);}
.dt{font-size:12px;color:var(--text3);}
.ptime{font-family:Georgia,serif;font-size:64px;font-weight:700;color:var(--cream);line-height:1;text-align:center;}
.plabel{font-size:13px;color:var(--text2);text-align:center;margin-top:.5rem;}
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
</head>
<body>
<style>
.z-lang-btn{flex:1;padding:8px;border:1px solid var(--border2);border-radius:8px;background:transparent;color:var(--text2);cursor:pointer;font-size:13px;font-weight:600;font-family:inherit}
.z-lang-btn.z-on{background:var(--gold);color:var(--surface2);border-color:var(--gold)}
.z-theme-btn{width:34px;height:34px;border-radius:50%;border:2px solid transparent;cursor:pointer}
.z-theme-btn.z-on{border-color:var(--cream)}
.z-mini{padding:5px 9px;border:1px solid var(--border2);border-radius:8px;background:transparent;color:var(--cream);cursor:pointer;font-size:15px;line-height:1.2;font-family:inherit}
.z-mini.z-on{border-color:var(--gold);background:rgba(255,255,255,.07)}
.z-sec-t{font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px}
.z-tog{display:flex;align-items:center;justify-content:space-between;padding:3px 0;font-size:13px;color:var(--cream)}
</style>
<button id="z-gear" onclick="zToggleSettings()" style="position:fixed;bottom:82px;left:16px;width:50px;height:50px;border-radius:50%;background:var(--surface);border:1px solid var(--border2);cursor:pointer;font-size:21px;z-index:150;color:var(--gold);box-shadow:0 4px 16px rgba(0,0,0,.4)">&#9881;</button>
<div id="z-settings" style="display:none;position:fixed;bottom:142px;left:16px;width:250px;max-height:72vh;overflow-y:auto;background:var(--surface);border:1px solid var(--border2);border-radius:16px;z-index:151;flex-direction:column;gap:16px;padding:16px;box-shadow:0 8px 24px rgba(0,0,0,.5)">
  <div><div class="z-sec-t">Idioma</div><div style="display:flex;gap:6px"><button class="z-lang-btn z-on" data-l="pt" onclick="setLang('pt')">PT</button><button class="z-lang-btn" data-l="es" onclick="setLang('es')">ES</button><button class="z-lang-btn" data-l="en" onclick="setLang('en')">EN</button></div></div>
  <div><div class="z-sec-t">Tema</div><div style="display:flex;gap:10px;flex-wrap:wrap">
    <button class="z-theme-btn z-on" data-t="meianoite" onclick="setTheme('meianoite')" title="Meia-noite" style="background:linear-gradient(135deg,#0A0E1A,#6A8FD4)"></button>
    <button class="z-theme-btn" data-t="rose" onclick="setTheme('rose')" title="Rose" style="background:linear-gradient(135deg,#160E14,#E0A9B0)"></button>
    <button class="z-theme-btn" data-t="lavanda" onclick="setTheme('lavanda')" title="Lavanda" style="background:linear-gradient(135deg,#120F1E,#B19CE8)"></button>
    <button class="z-theme-btn" data-t="esmeralda" onclick="setTheme('esmeralda')" title="Esmeralda" style="background:linear-gradient(135deg,#0A1410,#C9A86A)"></button>
  </div></div>
  <div><div class="z-sec-t">Cor de destaque</div><input type="color" id="z-accent" onchange="setAccent(this.value)" style="width:100%;height:30px;border:1px solid var(--border2);border-radius:8px;background:transparent;cursor:pointer"></div>
  <div><div class="z-sec-t">Abas</div><div id="z-tabs-ui"></div></div>
  <div><div class="z-sec-t">Ícones</div><div id="z-icons-ui"></div></div>
  <div><div class="z-sec-t">Áreas personalizadas</div><div id="z-areas-ui"></div></div>
  <button onclick="zLogout()" style="background:transparent;border:1px solid var(--border2);border-radius:8px;color:var(--text2);padding:8px;cursor:pointer;font-size:12px;font-family:inherit">Sair</button>
</div>

<div id="z-login" style="display:none;position:fixed;inset:0;background:#0A0E1A;z-index:9999;flex-direction:column;align-items:center;justify-content:center;padding:2rem;">
  <div style="font-family:Georgia,serif;font-size:30px;color:#E8EEF8;margin-bottom:2px">Zentra</div>
  <div style="font-size:13px;color:#7A9CC8;margin-bottom:1.5rem">Your missing wand.</div>
  <input id="z-email" type="email" placeholder="Email" autocomplete="username" style="width:100%;max-width:300px;padding:12px;margin-bottom:10px;border:1px solid #1E2A40;border-radius:10px;background:#04080F;color:#E8EEF8;font-size:15px;outline:none">
  <input id="z-pass" type="password" placeholder="Senha" autocomplete="current-password" onkeydown="if(event.key==='Enter')zLogin()" style="width:100%;max-width:300px;padding:12px;margin-bottom:10px;border:1px solid #1E2A40;border-radius:10px;background:#04080F;color:#E8EEF8;font-size:15px;outline:none">
  <button onclick="zLogin()" style="width:100%;max-width:300px;padding:12px;border:none;border-radius:10px;background:#6A8FD4;color:#04080F;font-size:15px;font-weight:600;cursor:pointer;font-family:inherit">Entrar</button>
  <button onclick="zSignup()" style="width:100%;max-width:300px;padding:11px;margin-top:9px;border:1px solid #6A8FD4;border-radius:10px;background:transparent;color:#6A8FD4;font-size:14px;font-weight:600;cursor:pointer;font-family:inherit">Criar conta</button>
  <div id="z-err" style="color:#E87070;font-size:13px;margin-top:10px;min-height:18px"></div>
</div>


<div id="app">
<!-- HOME -->
